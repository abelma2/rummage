# Your Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-sonnet-4-6).
# Use claude-haiku-4-5-20251001 for lower cost, or claude-opus-4-8 for max quality.
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: per-IP daily rate limit for a public demo (protects your API spend).
# Create a free database at https://upstash.com and paste its REST URL + token.
# Leave these unset and rate limiting is simply disabled.
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# RATELIMIT_PER_DAY=30
